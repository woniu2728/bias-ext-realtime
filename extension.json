{
  "id": "realtime",
  "name": "Realtime",
  "version": "0.1.0",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core",
    "users",
    "content"
  ],
  "optional_dependencies": [
    "notifications"
  ],
  "django": {
    "app_config": "bias_ext_realtime.backend.apps.RealtimeExtensionConfig",
    "app_label": "realtime",
    "migration_module": "bias_ext_realtime.backend.django_migrations"
  },
  "backend": {
    "entry": "bias_ext_realtime.backend.ext"
  },
  "extra": {
    "auto_install": true,
    "auto_enable": true
  },
  "performance_contracts": [
    {
      "name": "realtime_metrics",
      "message": "realtime metrics include connections, subscriptions and message counters.",
      "required_fields": [
        "active_connections",
        "active_subscriptions",
        "connection_count",
        "failed_send_count",
        "message_count",
        "subscription_count"
      ],
      "missing_fields": []
    }
  ],
  "security": {
    "capabilities_notice": "Realtime extension; exposes live update transport hooks and reads user/discussion visibility state."
  }
}
